<UserControl x:Class="TwitchAudioPlayer.WPF.Views.YtAudioTrackControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewModels="clr-namespace:TwitchAudioPlayer.WPF.ViewModels"
             xmlns:views="clr-namespace:TwitchAudioPlayer.WPF.Views"
             mc:Ignorable="d"
             d:DesignHeight="40" d:DesignWidth="500"
             d:DataContext="{d:DesignInstance Type=viewModels:YtAudioTrackViewModel, IsDesignTimeCreatable=True}"
             HorizontalAlignment="Stretch">
    <Grid Margin="0,0" Background="Transparent" Cursor="Hand" Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <views:AudioTrackControl Grid.Column="0" DataContext="{Binding AudioTrackViewModel}"
                                 Visibility="{Binding IsFailed, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
        <Grid Grid.Column="0" Margin="0 2"
              Visibility="{Binding IsFailed, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <materialDesign:PackIcon Grid.Column="0" Kind="AlertCircle" Width="28" Height="28"
                                     Foreground="Crimson" Margin="8 0" VerticalAlignment="Center" />

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding FailedTitle}" FontWeight="Bold" FontSize="13"
                           Foreground="{DynamicResource MaterialDesignBody}" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding FailedMessage}" FontSize="11" Foreground="Crimson"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <Button Grid.Column="2" Command="{Binding RetryCommand}"
                    Style="{StaticResource MaterialDesignIconButton}"
                    Width="32" Height="32" Margin="4 0 8 0"
                    ToolTip="Retry loading this track">
                <materialDesign:PackIcon Kind="Refresh" />
            </Button>
        </Grid>
        <Image Grid.Column="1" Source="{Binding SourceImage}" Width="25" Height="25" 
               Margin="0 0 10 0" Stretch="UniformToFill" VerticalAlignment="Center" />
    </Grid>
</UserControl>
